    @isTest
    public static void testGetMonthName() {
        for (Integer i=1; i<13; ++i) {
            String mesEspanol = ONE_PresseroSessionHelper.getMonthName(i, 'ESP');
            if (i==1) {
                System.assertEquals('Enero', mesEspanol, 'El mes no coincide para ESP');
            }
        } 
        
        for (Integer i=1; i<13; ++i) {
            String mesCatalan = ONE_PresseroSessionHelper.getMonthName(i, 'CAT');
            if (i==1) {
                System.assertEquals('Gener', mesCatalan, 'El mes no coincide para CAT');
            }
        }
        
        for (Integer i=1; i<13; ++i) {
            String mesEuskera = ONE_PresseroSessionHelper.getMonthName(i, 'EUS');
            if (i==1) {
                System.assertEquals('urtarrilaren', mesEuskera, 'El mes no coincide para EUS');
            }
        } 
        
        String mesInvalido = ONE_PresseroSessionHelper.getMonthName(1, 'INVALIDO');
        System.assertEquals('xxx', mesInvalido, 'No se devolvió xxx para un idioma no reconocido');
    }
    
